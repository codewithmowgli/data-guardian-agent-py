OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guardian_db

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=sf.inbound.events
KAFKA_GROUP_ID=guardian-agent-py-group

SALESFORCE_MOCK_MODE=true
SLACK_ENABLED=false

PRICE_CONFLICT_THRESHOLD=100
DUPLICATE_WINDOW_MINUTES=60
